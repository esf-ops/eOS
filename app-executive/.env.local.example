# Copy to ".env.local" for local or hosted static builds — NO BACKEND SECRETS HERE.

# Supabase Auth (anon key only — browser safe)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Executive API — full origin only, no path. Trailing `/` and trailing `/api` are stripped in app config.
# Do not leave this empty: an empty value makes the browser call the Vite dev server, not backend-core.
# Local:        http://localhost:3001
# Staging:      https://your-api-staging.example.com
VITE_BACKEND_URL=http://localhost:3001
