# Lab intelligence server (Phase 3.1 + 4B.4A) — placeholders only. Copy to server/.env (gitignored).
# Start: npm run live-server

QIL_LIVE_AI_ENABLED=false
QIL_AI_PROVIDER=gemini
# Required when live classification is enabled — do not hardcode a model name in source
QIL_AI_MODEL=
QIL_AI_VERIFICATION_MODEL=
QIL_AI_VERIFICATION_ENABLED=true
QIL_AI_TIMEOUT_MS=60000
QIL_AI_MAX_CONCURRENCY=2
# Classification body limit — do NOT raise for takeoff; takeoff has separate limits below
QIL_AI_MAX_BODY_BYTES=256000
QIL_ALLOWED_ORIGIN=http://127.0.0.1:5196
QIL_LAB_REQUEST_TOKEN=replace-with-local-lab-token
QIL_LIVE_SERVER_PORT=5197

# Primary lab credential (preferred) — reused by classification + takeoff; never expose to browser
QIL_GEMINI_API_KEY=

# Optional: allow reading GEMINI_API_KEY only with explicit opt-in (never silent)
# QIL_ALLOW_SHARED_GEMINI_KEY=false
# GEMINI_API_KEY=

# ── Phase 4B.4A live takeoff (independent from classification) ──────────────
QIL_LIVE_TAKEOFF_ENABLED=false
QIL_TAKEOFF_PROVIDER=gemini
# Required when live takeoff is enabled — do not hardcode model names in source
QIL_TAKEOFF_MODEL=
QIL_TAKEOFF_VERIFICATION_MODEL=
QIL_TAKEOFF_TIMEOUT_MS=90000
QIL_TAKEOFF_MAX_ATTACHMENT_BYTES=4000000
# Optional override; default derives from attachment limit + base64 overhead
# QIL_TAKEOFF_MAX_BODY_BYTES=
QIL_TAKEOFF_MAX_PAGES=20
QIL_TAKEOFF_MAX_CONCURRENCY=1
