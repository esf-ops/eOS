# Install Dashboard Head (app-install-dashboard)
#
# Copy from another staff head (.env) and adjust URLs.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_BACKEND_URL=http://localhost:3001
VITE_HEAD_URL_HOME=http://localhost:5177

# Optional: shared auth cookie domain for *.eliteosfab.com production hosts
# VITE_ELITEOS_AUTH_COOKIE_DOMAIN=.eliteosfab.com
