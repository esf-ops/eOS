# eOS root environment template (NO SECRETS)
# Copy to ".env" for local CLI sync scripts and optionally backend when run from repo root.

# -----------------------------------------------------------------------------
# Backend API + sync (server + scripts resolve dotenv from process cwd — usually repo root)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-backend-only

# Must be "1" for scripts that write Brain rows
SUPABASE_WRITE_ENABLED=0

# HTTP server (backend-core/src/server.js)
PORT=3001

# Cron / internal autosync callers — never expose to frontend
EOS_CRON_SECRET=generate-a-long-random-string

# Comma-separated browser origins for hosted heads (localhost Vite ports are merged automatically)
# EOS_ALLOWED_ORIGINS=https://YOUR-BRAIN-HEALTH-STAGING.vercel.app,https://YOUR-EXECUTIVE-STAGING.vercel.app

# Optional: uncomment only if you intend public unauthenticated sync health (default is guarded in code)
# EOS_ALLOW_PUBLIC_SYNC_HEALTH=0

# -----------------------------------------------------------------------------
# Moraware (backend / worker ONLY — never in Vite apps)
# -----------------------------------------------------------------------------
MORAWARE_API_URL=
MORAWARE_USERNAME=
MORAWARE_PASSWORD=
MORAWARE_ACCOUNT_ID=

# Common sync toggles — see docs/EOS_ENV_VARS.md for full inventory
MORAWARE_SYNC_MODE=global
MORAWARE_SYNC_START_DATE=2026-01-01
# MORAWARE_SYNC_END_DATE=
MORAWARE_MAX_SEARCH_PAGES=50
# MORAWARE_MAX_JOBS_TO_INGEST=
# MORAWARE_INGEST_ALL_MATCHING_JOBS=
# MORAWARE_INGEST_OPERATIONAL=0
