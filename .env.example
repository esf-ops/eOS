# eOS root environment template (NO SECRETS)
# Copy to ".env" for local CLI sync scripts and optionally backend when run from repo root.

# -----------------------------------------------------------------------------
# Backend API + sync (server + scripts resolve dotenv from process cwd — usually repo root)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-backend-only

# Must be "1" for scripts that write Brain rows
SUPABASE_WRITE_ENABLED=0

# HTTP server (backend-core/src/server.js)
PORT=3001

# Cron / internal autosync callers — never expose to frontend
EOS_CRON_SECRET=generate-a-long-random-string

# Comma-separated browser origins for hosted heads (localhost Vite ports are merged automatically)
# EOS_ALLOWED_ORIGINS=https://YOUR-BRAIN-HEALTH-STAGING.vercel.app,https://YOUR-EXECUTIVE-STAGING.vercel.app

# Optional: uncomment only if you intend public unauthenticated sync health (default is guarded in code)
# EOS_ALLOW_PUBLIC_SYNC_HEALTH=0

# -----------------------------------------------------------------------------
# Moraware (backend / worker ONLY — never in Vite apps)
# -----------------------------------------------------------------------------
MORAWARE_API_URL=
MORAWARE_USERNAME=
MORAWARE_PASSWORD=
MORAWARE_ACCOUNT_ID=

# Common sync toggles — see docs/EOS_ENV_VARS.md for full inventory
MORAWARE_SYNC_MODE=global
MORAWARE_SYNC_START_DATE=2026-01-01
# MORAWARE_SYNC_END_DATE=
MORAWARE_MAX_SEARCH_PAGES=50
# MORAWARE_MAX_JOBS_TO_INGEST=
# MORAWARE_INGEST_ALL_MATCHING_JOBS=
# MORAWARE_INGEST_OPERATIONAL=0

# Moraware Sync Foundation v1 import endpoint (server/worker only)
# Use a different long random value from EOS_CRON_SECRET if you want a dedicated importer secret.
MORAWARE_SYNC_IMPORT_SECRET=
# Optional: org UUID used by worker imports when payload does not include organization_id.
MORAWARE_DEFAULT_ORGANIZATION_ID=
# Manual snapshot import script:
# BACKEND_URL=http://localhost:3001
# MORAWARE_SYNC_IMPORT_FILE=debug/moraware/latest/sanitized-import.json
# MORAWARE_IMPORT_DRY_RUN=1
# MORAWARE_IMPORT_CHUNKED=1
# MORAWARE_IMPORT_ALLOW_LARGE_BASELINE=1
# MORAWARE_IMPORT_RESUME_GROUP_ID=
# MORAWARE_IMPORT_START_CHUNK_INDEX=1
# MORAWARE_IMPORT_MAX_PAYLOAD_BYTES=1500000
# MORAWARE_IMPORT_MAX_JOBS_PER_CHUNK=20
# MORAWARE_IMPORT_MAX_ACTIVITIES_PER_CHUNK=100
# MORAWARE_IMPORT_MAX_FORMS_PER_CHUNK=100
# MORAWARE_IMPORT_MAX_FILES_PER_CHUNK=50
# MORAWARE_IMPORT_MAX_ASSIGNEES_PER_CHUNK=50

# Tiny real snapshot generator (reads local ignored Moraware debug/export JSON and writes capped import payload)
# MORAWARE_SNAPSHOT_MODE=tiny
# MORAWARE_TINY_SOURCE_FILE=debug/moraware/latest/jobs/index.json
# Optional status/process sidecar, e.g. a Windows SDK job identifier export or status-bearing JSON rows.
# MORAWARE_TINY_STATUS_SOURCE_FILE=debug/moraware/latest/moraware-sdk-job-identifiers.json
# MORAWARE_TINY_OUTPUT_FILE=debug/moraware/import-tests/tiny-real-moraware-snapshot.json

# Small capped baseline mode (still local/ignored, not scheduled)
# MORAWARE_SNAPSHOT_MODE=baseline
# MORAWARE_TINY_OUTPUT_FILE=debug/moraware/baseline-tests/capped-baseline-moraware-snapshot.json
# MORAWARE_BASELINE_MAX_JOBS=50
# MORAWARE_BASELINE_MAX_ACTIVITIES=250
# MORAWARE_BASELINE_MAX_FORMS=250
# MORAWARE_BASELINE_MAX_FILES=250
# MORAWARE_BASELINE_MAX_ASSIGNEES=100

# Date-bounded 2026 baseline mode (manual only; read-only Moraware; ignored debug output)
# MORAWARE_SNAPSHOT_MODE=baseline_2026
# MORAWARE_BASELINE_START_DATE=2026-01-01
# MORAWARE_BASELINE_END_DATE=2026-05-18
# MORAWARE_TINY_OUTPUT_FILE=debug/moraware/baseline-2026/baseline-2026-moraware-snapshot.json
# MORAWARE_BASELINE_MAX_JOBS=5000
# MORAWARE_BASELINE_MAX_ACTIVITIES=50000
# MORAWARE_BASELINE_MAX_FORMS=50000
# MORAWARE_BASELINE_MAX_FILES=10000
# MORAWARE_BASELINE_MAX_ASSIGNEES=1000

# Live capped Moraware snapshot runner (read-only Moraware; writes ignored debug snapshot only)
# MORAWARE_LIVE_MAX_JOBS=100
# MORAWARE_LIVE_MAX_ACTIVITIES=500
# MORAWARE_LIVE_MAX_FORMS=500
# MORAWARE_LIVE_MAX_FILES=250
# MORAWARE_LIVE_MAX_ASSIGNEES=100
