# Browser-safe vars only — copy to .env.local for local dev.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Backend API (strip trailing slashes; do not end with /api)
VITE_BACKEND_URL=http://localhost:3001

# Optional overrides for launcher “Open head” buttons (local dev only — omit to use localhost defaults below).
# Never set VITE_HEAD_URL_* or legacy VITE_*_URL to localhost on Vercel production; production Home trusts Brain `/api/me/heads` only.
# VITE_HEAD_URL_EXECUTIVE=http://localhost:5175
# VITE_HEAD_URL_BRAIN_HEALTH=http://localhost:5174
# VITE_HEAD_URL_ORG_DIRECTORY=http://localhost:5184
# VITE_EXECUTIVE_URL=http://localhost:5175
# VITE_BRAIN_HEALTH_URL=http://localhost:5174
# VITE_SYSTEM_ADMIN_URL=http://localhost:5176
