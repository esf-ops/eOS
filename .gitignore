# Dependencies & build artifacts
node_modules/
dist/
**/dist/
.cache/

# OS / tooling
.DS_Store

# Secrets & local overrides (never commit)
.env
.env.local
**/.env.local
.env.*
!.env.example
!**/.env.example
!.env.local.example
!**/.env.local.example

# Pipeline / Moraware dumps and generated import-test snapshots (often large; may contain operational data — keep local only)
out*.json
debug/

# Worker env copies inside repo (production path is /etc/eliteos/moraware-worker.env)
deploy/moraware-worker/moraware-worker.env
**/moraware-worker.env
!**/moraware-worker.env.example

# .NET build artifacts
**/bin/
**/obj/

# Local/vendor SDK binaries
tools/moraware-sdk-trace/lib/*.dll
!tools/moraware-sdk-trace/lib/.gitkeep
.vercel
debug/slabsmith/source-samples/
