# app-kiosk — public showroom kiosk presentation
#
# ALL values here are PUBLIC. Never put secrets, service-role keys, provider
# API keys, or internal API URLs in this file — it ships to the browser.
#
# Each section of the kiosk can point at an existing public tool. Leave a value
# blank to render the polished built-in "Open section" hero instead of an iframe.

# Premium showroom color collection (Elite 100). Public URL only.
VITE_KIOSK_ELITE100_URL=

# Sinks, faucets, and accessories catalog. Public URL only.
VITE_KIOSK_PRODUCT_CATALOG_URL=

# Available slabs and remnants (public-safe view only — no costs/IDs/availability).
VITE_KIOSK_LIVE_INVENTORY_URL=

# Countertop visualizer. Defaults to https://visualizer.eliteosfab.com when blank.
VITE_KIOSK_VISUALIZER_URL=https://visualizer.eliteosfab.com

# Optional: override the public base URL used to build showroom deep links and
# the visualizer QR code. Defaults to https://kiosk.eliteosfab.com
VITE_KIOSK_PUBLIC_BASE_URL=https://kiosk.eliteosfab.com

# Optional: idle timeout (ms) before returning to the home attract screen.
# Defaults to 120000 (2 minutes).
VITE_KIOSK_IDLE_MS=120000
