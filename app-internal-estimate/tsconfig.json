{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@quote-lib/*": ["../app-quote/src/lib/*"],
      "@quote-ui/*": ["../app-quote/src/ui/*"]
    }
  },
  "include": [
    "src",
    "../shared/eliteos-supabase/**/*.ts",
    "../shared/eliteos-ui/**/*.ts",
    "../shared/eliteos-ui/**/*.tsx"
  ]
}
