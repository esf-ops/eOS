# Backend API base URL for local dev (Brain on port 3001).
# Leave unset in production when the public head is served same-origin behind the API gateway.
VITE_BACKEND_URL=http://127.0.0.1:3001

# UI kill-switch — never grants access. Exact "false" forces the read-only frozen summary.
# Unset or any other value allows ConfigurationView when the v2 session returns an active envelope.
# Production customer experience: leave unset or set true. Set false only to force legacy fallback.
VITE_DIGITAL_ESTIMATE_CONFIGURATION_UI_ENABLED=true

# UI-only — never grants access. Exact "true" shows review-request panel after saved configuration.
VITE_DIGITAL_ESTIMATE_REVIEW_UI_ENABLED=false

# Note: public access also requires server DIGITAL_ESTIMATE_PUBLIC_CONFIGURATION_ENABLED=1
# (and related runtime flags). v1 read-only baseline can work without public configuration.
