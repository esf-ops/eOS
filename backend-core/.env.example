# backend-core HTTP API-only template (NO SECRETS)
#
# Deployments that run ONLY `node backend-core/src/server.js` set these on the host.
# For local full-stack dev Moraware/sync variables usually live in the repo root `.env`
# — see /.env.example and docs/EOS_ENV_VARS.md .

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-backend-only

PORT=3001

# Required if you call POST / internal sync endpoints with x-eos-cron-secret
EOS_CRON_SECRET=

# Moraware Sync Foundation v1 import endpoint (server/worker only; never frontend)
# POST /api/internal/moraware-sync/import accepts x-moraware-sync-secret or x-eos-cron-secret.
MORAWARE_SYNC_IMPORT_SECRET=
# Optional org UUID used when worker payloads do not include organization_id.
MORAWARE_DEFAULT_ORGANIZATION_ID=

# Staging/production frontends — comma-separated HTTPS origins (no trailing path)
# Example:
# EOS_ALLOWED_ORIGINS=https://YOUR-BRAIN-HEALTH-STAGING.vercel.app,https://YOUR-EXECUTIVE-STAGING.vercel.app
#
# Optional aliases (same comma-separated format, merged additively with EOS_ALLOWED_ORIGINS):
# ALLOWED_ORIGINS=https://...
# CORS_ALLOWED_ORIGINS=https://...
#
# eliteOSfab production (see docs/eliteos/domain-routing-plan.md):
# EOS_ALLOWED_ORIGINS=https://www.eliteosfab.com,https://eliteosfab.com,https://system.eliteosfab.com,https://internal.eliteosfab.com,https://quotes.eliteosfab.com,https://pricing.eliteosfab.com,https://quote.eliteosfab.com,https://estimate.eliteosfab.com
#
# On Vercel production (`VERCEL_ENV=production`), HTTPS origins under *.eliteosfab.com are also accepted when the
# Browser sends that exact Origin (still reflected — never "*"). Opt out with:
# EOS_TRUST_ELITEOSFAB_SUBDOMAIN_ORIGINS=0

# Supabase invite + recovery emails: redirect users here (must match Supabase Dashboard → Auth → Redirect URLs)
# SUPABASE_INVITE_REDIRECT_URL=https://www.eliteosfab.com/auth/callback
#
# Fallbacks (if unset): ELITEOS_HOME_URL / HEAD_URL_HOME append /auth/callback; localhost SITE_URL is ignored for invites.
# See docs/eliteos/domain-routing-plan.md

# Launcher / head deployment URLs (no secrets) — used by GET /api/me/heads
# Production Brain must set each deployed head you want “Available” on eliteOS Home.
# Never set HEAD_URL_* to localhost, 127.0.0.1, private LAN, or http:// on production — Brain strips them (heads show as Coming Soon).
# Production detection: NODE_ENV=production or VERCEL_ENV=production.
# Legacy alias: HEAD_URL_QUOTE works for Internal Estimate (same as HEAD_URL_INTERNAL_ESTIMATE).
#
# HEAD_URL_HOME=https://www.eliteosfab.com
# HEAD_URL_PUBLIC_QUOTE=https://quote.eliteosfab.com
# HEAD_URL_INTERNAL_ESTIMATE=https://internal.eliteosfab.com
# HEAD_URL_AI_TAKEOFF=https://takeoff.eliteosfab.com
# Used by Monday internal sync deep-link payload (optional text column mapping later).

# Monday.com (server-side only — never expose MONDAY_API_TOKEN to browsers)
# MONDAY_API_TOKEN=
# MONDAY_INTERNAL_QUOTES_BOARD_ID=
# MONDAY_SYNC_DRY_RUN=0
# MONDAY_INTERNAL_ALLOW_TITLE_COLUMN_MATCH=1
# MONDAY_INTERNAL_GROUP_NEW_QUOTES=
# MONDAY_INTERNAL_GROUP_IN_REVIEW=
# MONDAY_INTERNAL_GROUP_APPROVED_QUOTES=
# Internal Estimates column IDs (from: node backend-core/src/scripts/inspectMondayBoardColumns.js --internal)
# MONDAY_INTERNAL_COL_QUOTE_ID=
# MONDAY_INTERNAL_COL_QUOTE_DATE=
# MONDAY_INTERNAL_COL_SALESPERSON=
# MONDAY_INTERNAL_COL_ACCOUNT=
# MONDAY_INTERNAL_COL_ESTIMATED_BY=
# MONDAY_INTERNAL_COL_BRANCH=
# MONDAY_INTERNAL_COL_EST_SQ_FT=
# MONDAY_INTERNAL_COL_QUOTE_AMOUNT=
# MONDAY_INTERNAL_COL_ROOM_COUNT=
# MONDAY_INTERNAL_COL_STATUS=
# MONDAY_INTERNAL_COL_PHONE=
# MONDAY_INTERNAL_COL_EMAIL=
# MONDAY_INTERNAL_COL_PROJECT_ADDRESS=
# MONDAY_INTERNAL_COL_CITY=
# MONDAY_INTERNAL_COL_STATE=
# MONDAY_INTERNAL_COL_ESTIMATE_SUMMARY=
# MONDAY_INTERNAL_COL_ESTIMATE_LINK=
# Monday Status labels (must match labels on the Internal Estimates board)
# MONDAY_INTERNAL_STATUS_DRAFT_LABEL=Pending
# MONDAY_INTERNAL_STATUS_IN_REVIEW_LABEL=Pending
# MONDAY_INTERNAL_STATUS_SENT_LABEL=In Negotiation
# MONDAY_INTERNAL_STATUS_SOLD_LABEL=Accepted
# MONDAY_INTERNAL_STATUS_REJECTED_LABEL=Rejected
# Legacy / optional extras:
# MONDAY_INTERNAL_COL_REVISION=
# MONDAY_INTERNAL_COL_LAST_REVISED=
# HEAD_URL_QUOTE_LIBRARY=https://quotes.eliteosfab.com
# HEAD_URL_PRICING_ADMIN=https://pricing.eliteosfab.com
# HEAD_URL_SYSTEM_ADMIN=https://system.eliteosfab.com
# HEAD_URL_ORG_DIRECTORY=https://org.eliteosfab.com
# HEAD_URL_EXECUTIVE=https://...
# HEAD_URL_BRAIN_HEALTH=https://...
# HEAD_URL_SALES=https://sales.eliteosfab.com
# HEAD_URL_PRODUCTION=https://...
# HEAD_URL_SHOP_TV=https://...
# HEAD_URL_INSTALL=https://...
# HEAD_URL_PURCHASING=https://...
# HEAD_URL_CUSTOMER_SERVICE=https://...
# HEAD_URL_HR=https://...
# HEAD_URL_SAFETY=https://...
# HEAD_URL_MARKETING=https://...
# HEAD_URL_FINANCE=https://...
# HEAD_URL_REPORTS=https://...
# Partner Quote head (app-partner-quote) — internal pilot UI
# HEAD_URL_PARTNER_QUOTE=https://partner-quote.eliteosfab.com
# HEAD_URL_DEALER_RESOURCES=https://...

# Partner Quote leakage verification (dev/staging only — see docs/quote-platform/partner-quote-leakage-verification.md)
# PARTNER_LEAK_TEST_CONFIRM=yes
# PARTNER_LEAK_USER_A_EMAIL=
# PARTNER_LEAK_USER_A_PASSWORD=
# PARTNER_LEAK_USER_B_EMAIL=
# PARTNER_LEAK_USER_B_PASSWORD=
# PARTNER_LEAK_PARTNER_A_ID=
# PARTNER_LEAK_PARTNER_B_ID=
# PARTNER_LEAK_ORGANIZATION_ID=
# PARTNER_LEAK_SKIP_SUBMIT=0

# ── AI Takeoff Lab (backend-core/src/takeoff/) ────────────────────────────────
# Set TAKEOFF_AI_ENABLED=1 to enable AI extraction.
# Set TAKEOFF_AI_PROVIDER to choose the AI backend (default: openai).
#
# OpenAI provider (default):
#   TAKEOFF_AI_PROVIDER=openai
#   TAKEOFF_AI_MODEL=gpt-4o
#   OPENAI_API_KEY=sk-...
#
# Gemini provider (v5.9: for benchmarked model comparison):
#   TAKEOFF_AI_PROVIDER=gemini
#   GEMINI_TAKEOFF_MODEL=gemini-2.5-pro
#   GEMINI_API_KEY=
#
# To switch to Gemini for a benchmarked run:
#   TAKEOFF_AI_ENABLED=1
#   TAKEOFF_AI_PROVIDER=gemini
#   GEMINI_TAKEOFF_MODEL=gemini-2.5-pro
#   GEMINI_API_KEY=<your Gemini API key — never commit>
TAKEOFF_AI_ENABLED=0
# TAKEOFF_AI_PROVIDER=openai
# TAKEOFF_AI_MODEL=gpt-4o
# OPENAI_API_KEY=
# TAKEOFF_AI_PROVIDER=gemini
# GEMINI_TAKEOFF_MODEL=gemini-2.5-pro
# GEMINI_API_KEY=

# Optional diagnostics
# EOS_ALLOW_PUBLIC_SYNC_HEALTH=0
