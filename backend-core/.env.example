# HEAD_URL_SAFETY=https://...
# HEAD_URL_MARKETING=https://...
# HEAD_URL_FINANCE=https://...
# HEAD_URL_REPORTS=https://...
# Partner Quote head (app-partner-quote) — internal pilot UI
# HEAD_URL_PARTNER_QUOTE=https://partner-quote.eliteosfab.com
# HEAD_URL_DEALER_RESOURCES=https://...

# Partner Quote leakage verification (dev/staging only — see docs/quote-platform/partner-quote-leakage-verification.md)
# PARTNER_LEAK_TEST_CONFIRM=yes
# PARTNER_LEAK_USER_A_EMAIL=
# PARTNER_LEAK_USER_A_PASSWORD=
# PARTNER_LEAK_USER_B_EMAIL=
# PARTNER_LEAK_USER_B_PASSWORD=
# PARTNER_LEAK_PARTNER_A_ID=
# PARTNER_LEAK_PARTNER_B_ID=
# PARTNER_LEAK_ORGANIZATION_ID=
# PARTNER_LEAK_SKIP_SUBMIT=0

# ── AI Takeoff Lab (backend-core/src/takeoff/) ────────────────────────────────
# Set TAKEOFF_AI_ENABLED=1 to enable AI extraction.
# Set TAKEOFF_AI_PROVIDER to choose the AI backend (default: openai).
# Hosted durability: waitUntil is best-effort; Vercel cron hits
# GET|POST /api/internal/takeoff/process-queued every minute to reclaim stuck jobs.
# TAKEOFF_AI_STALE_MS=90000
#
# OpenAI provider (default):
#   TAKEOFF_AI_PROVIDER=openai
#   TAKEOFF_AI_MODEL=gpt-4o
#   OPENAI_API_KEY=sk-...
#
# Gemini provider (v5.9: for benchmarked model comparison):
#   TAKEOFF_AI_PROVIDER=gemini
#   GEMINI_TAKEOFF_MODEL=gemini-2.5-pro
#   GEMINI_API_KEY=
#
# To switch to Gemini for a benchmarked run:
#   TAKEOFF_AI_ENABLED=1
#   TAKEOFF_AI_PROVIDER=gemini
#   GEMINI_TAKEOFF_MODEL=gemini-2.5-pro
#   GEMINI_API_KEY=<your Gemini API key — never commit>
#
# Exayard provider (platform API — workflow v1: upload → analysis → poll):
#   TAKEOFF_AI_PROVIDER=exayard
#   EXAYARD_API_BASE_URL=https://api.exayard.com/v1
#   EXAYARD_API_KEY=
#   EXAYARD_ORGANIZATION_ID=
#   EXAYARD_POLL_INTERVAL_MS=3000
#   EXAYARD_INITIAL_POLL_TIMEOUT_MS=45000
#   EXAYARD_POLL_TIMEOUT_MS=300000
#   EXAYARD_PAGES_POLL_TIMEOUT_MS=120000
# EXAYARD_PAGES_POLL_TIMEOUT_MS=120000

# ── Countertop Visualizer (backend-core/src/visualizer/) ─────────────────────
# Concept-only AI countertop rendering — separate from AI Takeoff (/api/takeoff/*).
# PUBLIC_VISUALIZER_USE_ELITE100_ASSETS=1
# PUBLIC_VISUALIZER_ORGANIZATION_ID=            # org UUID; falls back to SLABOS_ORGANIZATION_ID
# PUBLIC_VISUALIZER_STATIC_TEXTURE_BASE_URL=https://visualizer.eliteosfab.com
# PUBLIC_VISUALIZER_ENABLED=1
# PUBLIC_VISUALIZER_RENDER_ENABLED=1
# PUBLIC_VISUALIZER_MAX_UPLOAD_MB=10
# PUBLIC_VISUALIZER_MAX_RENDERS_PER_IP_PER_HOUR=12
# VISUALIZER_RENDER_ENABLED=1
# VISUALIZER_RENDER_PROVIDER=gemini
# VISUALIZER_RENDER_MODEL=gemini-2.0-flash-preview-image-generation
# VISUALIZER_MAX_UPLOAD_MB=10
# GEMINI_API_KEY=            # reused when VISUALIZER_RENDER_PROVIDER=gemini
# OPENAI_API_KEY=            # reused when VISUALIZER_RENDER_PROVIDER=openai
# HEAD_URL_VISUALIZER=https://visualizer.eliteosfab.com

TAKEOFF_AI_ENABLED=0
# TAKEOFF_AI_PROVIDER=openai
# TAKEOFF_AI_MODEL=gpt-4o
# OPENAI_API_KEY=
# TAKEOFF_AI_PROVIDER=gemini
# GEMINI_TAKEOFF_MODEL=gemini-2.5-pro
# GEMINI_API_KEY=
# TAKEOFF_AI_PROVIDER=exayard
# EXAYARD_API_BASE_URL=https://api.exayard.com/v1
# EXAYARD_API_KEY=
# EXAYARD_ORGANIZATION_ID=
# EXAYARD_POLL_INTERVAL_MS=3000
# EXAYARD_POLL_TIMEOUT_MS=300000
# EXAYARD_PAGES_POLL_TIMEOUT_MS=120000

# Optional diagnostics
# EOS_ALLOW_PUBLIC_SYNC_HEALTH=0

# ── Quote Delivery / Email Estimate (backend-only) ────────────────────────────
# Send is OFF by default. Preview never sends email regardless of these flags.
# QUOTE_EMAIL_SEND_ENABLED=0
# QUOTE_EMAIL_PROVIDER=resend
# QUOTE_EMAIL_FROM=Elite Stone Fabrication <quotes@eliteosfab.com>
# Comma-separated allowlist for recipient domains (empty = no domain restriction when send enabled)
# QUOTE_EMAIL_ALLOWED_DOMAINS=eliteosfab.com
# Non-production safety: redirect all real sends to this address (intended recipients logged in delivery metadata)
# QUOTE_EMAIL_FORCE_RECIPIENT=ops@eliteosfab.com
# Customer PDF email attachment (requires saved customer_estimate_print_snapshot on quote)
# QUOTE_EMAIL_PDF_ENABLED=0
# Public HTTPS logo URL for estimate email HTML (Gmail/Outlook-safe; not used for PDF print)
# QUOTE_EMAIL_LOGO_URL=https://www.elitestonefabrication.com/wp-content/uploads/2021/09/cropped-ESF-Horizontal-Logo-500x150-px_09_09.png
# Optional local Chromium path when @sparticuz/chromium is unavailable (e.g. macOS Google Chrome)
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Resend (backend only — never expose to frontend or client bundles):
# RESEND_API_KEY=re_...
# SQL (manual apply): backend-core/supabase/eliteos_quote_delivery_foundation.sql

# ── Digital Estimate (Phase DE.1) — server-only, OFF by default ───────────────
# Exact "1" enables. Do not enable in production without applying eliteos_digital_estimate_v1.sql.
# Public host is documented as digital.eliteosfab.com — do NOT use estimate.eliteosfab.com (IE alias).
# DIGITAL_ESTIMATE_API_ENABLED=0
# DIGITAL_ESTIMATE_PUBLISH_ENABLED=0
# DIGITAL_ESTIMATE_PUBLIC_READ_ENABLED=0
# HEAD_URL_DIGITAL_ESTIMATE=https://digital.eliteosfab.com
# DIGITAL_ESTIMATE_ACCESS_TTL_DAYS=90
# DIGITAL_ESTIMATE_PRICING_VALID_DAYS=30
# DIGITAL_ESTIMATE_PUBLIC_RATE_LIMIT_PER_MINUTE=60
# DIGITAL_ESTIMATE_VIEW_THROTTLE_SECONDS=300
# Staff-recoverable stable customer URLs (AES-GCM wrap for token_wrapped column):
# DIGITAL_ESTIMATE_LINK_WRAP_KEY=replace-with-long-random-secret
# DIGITAL_ESTIMATE_ALLOW_DEV_LINK_WRAP=0
# SQL (manual apply — NOT applied by DE.1 automation):
#   backend-core/supabase/eliteos_digital_estimate_v1.sql
#   backend-core/supabase/eliteos_digital_estimate_reusable_links_v1.sql

# ── Elite 100 Estimate Studio (Phase DE.1.1) — private pilot, OFF by default ──
# Staff Digital Estimate publish controls live here (not Internal Estimate / Quote Library).
# ELITE100_ESTIMATE_STUDIO_ENABLED=0
# ELITE100_ESTIMATE_STUDIO_PILOT_USER_IDS=
# ELITE100_ESTIMATE_STUDIO_PILOT_EMAILS=
# HEAD_URL_ELITE100_ESTIMATE_STUDIO=https://elite100.eliteosfab.com
# Assign head slug elite100_estimate_studio via System Admin Access Scope to the owner only.
# Empty pilot lists ⇒ nobody authorized (fail closed). Never put pilot IDs in VITE_*.
#
# Studio estimate (scope → calculate → approve) — Supabase default; memory for tests only.
# ELITE100_STUDIO_ESTIMATE_REPOSITORY=supabase
# Apply manually: backend-core/supabase/eliteos_studio_estimates_v1.sql
# ELITE100_STUDIO_ESTIMATE_REPOSITORY=memory
# Trusted partner_account_id allowlists (comma-separated UUIDs). Never infer from customer name.
# ELITE100_TRUSTED_WATTS_PARTNER_ACCOUNT_IDS=
# ELITE100_TRUSTED_SPAHN_PARTNER_ACCOUNT_IDS=
# Users allowed to apply internal material markup (comma-separated auth user UUIDs). Empty ⇒ nobody.
# ELITE100_INTERNAL_MARKUP_ALLOWED_USER_IDS=

# ── Quote Intake Microsoft Graph (Phase 6P.4) — server-only, off by default ──
# Never set these as VITE_*. Never commit real secrets.
# Exchange RBAC must remain Application Mail.Read scoped to quotes@ only.
# QUOTE_INTAKE_API_ENABLED=0
# After supported single-PDF intake: auto open-estimate + async AI queue (default ON when API enabled).
# Set 0 to disable automatic AI Takeoff (manual Open Estimate still works).
# QUOTE_INTAKE_AUTOMATIC_TAKEOFF=1
# QUOTE_INTAKE_GRAPH_ENABLED=0
# QUOTE_INTAKE_GRAPH_MANUAL_SYNC_ENABLED=0
# QUOTE_INTAKE_GRAPH_TENANT_ID=
# QUOTE_INTAKE_GRAPH_CLIENT_ID=
# QUOTE_INTAKE_GRAPH_CLIENT_SECRET=
# QUOTE_INTAKE_GRAPH_MAILBOX=quotes@elitestonefabrication.com
# QUOTE_INTAKE_GRAPH_TIMEOUT_MS=30000
# QUOTE_INTAKE_GRAPH_PREVIEW_LIMIT=25
# QUOTE_INTAKE_GRAPH_IMPORT_LIMIT=10
# Authoritative single-PDF ceiling for mailbox → Open Estimate (default 50 MiB, hard max 100 MiB).
# QUOTE_INTAKE_MAX_PDF_BYTES=52428800
# Legacy aliases (used only when QUOTE_INTAKE_MAX_PDF_BYTES is unset):
# QUOTE_INTAKE_GRAPH_MAX_ATTACHMENT_BYTES=52428800
# QUOTE_INTAKE_GRAPH_MAX_TOTAL_BYTES=52428800
