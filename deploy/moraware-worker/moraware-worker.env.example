# eliteOS Moraware cloud worker environment (example only — no real secrets)
#
# Copy to a path OUTSIDE Git on the VM, e.g.:
#   sudo mkdir -p /etc/eliteos
#   sudo cp deploy/moraware-worker/moraware-worker.env.example /etc/eliteos/moraware-worker.env
#   sudo chmod 600 /etc/eliteos/moraware-worker.env
#   sudo chown eliteos:eliteos /etc/eliteos/moraware-worker.env
#
# Never commit /etc/eliteos/moraware-worker.env or any file containing live credentials.

# --- Moraware HTTP pull (worker only) ---
MORAWARE_API_URL=https://moraware.example.com/api
MORAWARE_USERNAME=your-moraware-username
MORAWARE_PASSWORD=your-moraware-password

# --- Org + backend target ---
MORAWARE_DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
BACKEND_URL=https://your-backend.vercel.app

# --- Internal API auth (must match Vercel backend env) ---
MORAWARE_SYNC_IMPORT_SECRET=your-import-secret
EOS_CRON_SECRET=your-cron-secret

# --- Snapshot mode (Sales YTD baseline) ---
MORAWARE_SNAPSHOT_MODE=baseline_2026
MORAWARE_BASELINE_START_DATE=2026-01-01
# MORAWARE_BASELINE_END_DATE defaults to today in the runner when omitted

# --- Large baseline import guards ---
MORAWARE_IMPORT_ALLOW_LARGE_BASELINE=1
MORAWARE_IMPORT_CHUNKED=1
MORAWARE_IMPORT_DRY_RUN=0

# --- Chunk sizing (tune for Vercel payload limits; keep stable for resume) ---
MORAWARE_IMPORT_MAX_PAYLOAD_BYTES=750000
MORAWARE_IMPORT_MAX_JOBS_PER_CHUNK=50
MORAWARE_IMPORT_MAX_ACTIVITIES_PER_CHUNK=500
MORAWARE_IMPORT_MAX_FORMS_PER_CHUNK=1000
MORAWARE_IMPORT_MAX_FILES_PER_CHUNK=50
MORAWARE_IMPORT_MAX_ASSIGNEES_PER_CHUNK=100

# --- Optional baseline caps (raise only after reviewing cap_warnings) ---
# MORAWARE_BASELINE_MAX_JOBS=5000
# MORAWARE_BASELINE_MAX_ACTIVITIES=50000
# MORAWARE_BASELINE_MAX_FORMS=50000
# MORAWARE_BASELINE_MAX_FILES=10000
# MORAWARE_BASELINE_MAX_ASSIGNEES=1000

# --- Worker paths (optional overrides for wrapper script) ---
# ELITEOS_REPO=/opt/eliteos/eOS
# ELITEOS_ENV=/etc/eliteos/moraware-worker.env

# --- Calendar schedule feed (Install Dashboard, view 222) ---
# Direct Supabase writes — BACKEND_URL is NOT used for this job.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_WRITE_ENABLED=1
# MORAWARE_REPORT_VIEW_ID=222
# MORAWARE_CALENDAR_SCHEDULE_ARTIFACT_DIR=/opt/eliteos/eOS/debug/moraware/scheduled-runs/calendar-schedule
# Do NOT set MORAWARE_CALENDAR_SCHEDULE_ALLOW_EMPTY=1 on the production timer.

# --- Failure recovery ONLY (do not set in normal nightly env) ---
# Uncomment and run manually via wrapper or one-off shell — never in cron.
# MORAWARE_PIPELINE_SKIP_GENERATE=1
# MORAWARE_IMPORT_RESUME_GROUP_ID=00000000-0000-0000-0000-000000000000
# MORAWARE_IMPORT_START_CHUNK_INDEX=200
